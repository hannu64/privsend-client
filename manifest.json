{
  "manifest_version": 3,
  "name": "PrivSend — one-time encrypted secrets",
  "version": "1.0.0",
  "version_name": "1.0.0 (2026-07-22)",
  "description": "Send end-to-end-encrypted, one-time secrets and files. The encryption runs on your device from this installed, audited copy — the server only ever sees ciphertext.",
  "browser_specific_settings": {
    "gecko": {
      "id": "support@zumitomi.fi",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["personalCommunications"]
      }
    }
  },
  "icons": {
    "16": "static/ext-icon-16.png",
    "32": "static/ext-icon-32.png",
    "48": "static/ext-icon-48.png",
    "128": "static/ext-icon-128.png"
  },
  "action": {
    "default_title": "New PrivSend secret",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "static/ext-icon-16.png",
      "32": "static/ext-icon-32.png",
      "48": "static/ext-icon-48.png",
      "128": "static/ext-icon-128.png"
    }
  },
  "host_permissions": [
    "https://privsend.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://privsend.app/s/*"],
      "js": ["intercept-reveal.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["reveal.html"],
      "matches": ["https://privsend.app/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src https://privsend.app; img-src 'self' data:; object-src 'none'"
  }
}
